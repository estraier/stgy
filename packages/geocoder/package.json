{
  "name": "stgy-geocoder",
  "version": "1.0.0",
  "private": true,
  "author": "Mikio Hirabayashi",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "jest",
    "encode": "npm run build --silent && node dist/cli.js encode",
    "decode": "npm run build --silent && node dist/cli.js decode",
    "fmt": "prettier --write .",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf node_modules dist && find source-data -type f -name '*.zip' -delete",
    "generate:japan": "./scripts/generate-japan.sh",
    "validate:data": "./scripts/validate-generated.py data/geo-japan.ndjson"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "jest": "^29.7.0",
    "prettier": "^3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
