{
  "name": "stgy-track",
  "version": "1.0.0",
  "private": true,
  "description": "Leaflet-based TrackJSON and FIT route viewer for HTML pages",
  "author": "Mikio Hirabayashi",
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./activity": {
      "types": "./dist/activity.d.ts",
      "require": "./dist/activity.js",
      "default": "./dist/activity.js"
    },
    "./analysis": {
      "types": "./dist/analysis.d.ts",
      "require": "./dist/analysis.js",
      "default": "./dist/analysis.js"
    },
    "./fit": {
      "types": "./dist/fit.d.ts",
      "require": "./dist/fit.js",
      "default": "./dist/fit.js"
    },
    "./gpx": {
      "types": "./dist/gpx.d.ts",
      "require": "./dist/gpx.js",
      "default": "./dist/gpx.js"
    },
    "./trackjson": {
      "types": "./dist/trackjson.d.ts",
      "require": "./dist/trackjson.js",
      "default": "./dist/trackjson.js"
    },
    "./trackjson.schema.json": "./trackjson.schema.json",
    "./track-viewer.js": "./dist/track-viewer.js",
    "./track-viewer.css": "./dist/track-viewer.css",
    "./fit-demo.js": "./dist/fit-demo.js"
  },
  "files": [
    "dist",
    "README.md",
    "TRACKJSON.md",
    "CHANGELOG.md",
    "LICENSE",
    "trackjson.schema.json"
  ],
  "sideEffects": [
    "*.css",
    "dist/*.css",
    "src/**/*.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy:assets",
    "copy:assets": "node scripts/copy-assets.js",
    "dev": "tsc -w -p tsconfig.json",
    "check": "tsc --noEmit",
    "bundle": "npm run bundle:viewer && npm run bundle:fit-demo",
    "bundle:viewer": "esbuild src/browser.ts --bundle --minify --outfile=dist/track-viewer.js --format=iife --global-name=StgyTrackViewer --loader:.png=dataurl --loader:.svg=dataurl",
    "bundle:fit-demo": "esbuild src/fit-demo.ts --bundle --minify --outfile=dist/fit-demo.js --format=iife --global-name=StgyFitDemo",
    "test": "jest",
    "lint": "eslint src",
    "verify": "npm run test && npm run check && npm run lint",
    "dist": "npm run clean && npm run build && npm run bundle",
    "serve:examples": "python3 -m http.server 8000",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "sh scripts/check-release.sh",
    "prepack": "npm run dist",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@garmin/fitsdk": "^21.208.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.11.19",
    "esbuild": "^0.20.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0"
  }
}
