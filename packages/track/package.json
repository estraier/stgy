{
  "name": "stgy-track",
  "version": "1.0.0",
  "private": true,
  "author": "Mikio Hirabayashi",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "check": "tsc --noEmit",
    "bundle": "esbuild src/index.ts --bundle --minify --outfile=dist/track-viewer.js --format=iife --global-name=StgyTrackViewer --loader:.png=dataurl --loader:.svg=dataurl",
    "test": "jest",
    "lint": "eslint src",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.6.3",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.11.19",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "jest-environment-jsdom": "^29.7.0",
    "@types/jest": "^29.5.14",
    "prettier": "^3.0.0"
  }
}
