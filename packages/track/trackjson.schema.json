{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stgy.example/schemas/trackjson.schema.json",
  "title": "TrackJSON",
  "description": "GeoJSON-compatible route data format for stgy-track.",
  "oneOf": [
    {
      "$ref": "#/$defs/featureCollection"
    },
    {
      "$ref": "#/$defs/feature"
    }
  ],
  "$defs": {
    "featureCollection": {
      "type": "object",
      "required": [
        "type",
        "features"
      ],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/feature"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      },
      "additionalProperties": true
    },
    "feature": {
      "type": "object",
      "required": [
        "type",
        "geometry",
        "properties"
      ],
      "properties": {
        "type": {
          "const": "Feature"
        },
        "geometry": {
          "$ref": "#/$defs/lineStringGeometry"
        },
        "properties": {
          "$ref": "#/$defs/properties"
        }
      },
      "additionalProperties": true
    },
    "lineStringGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/position"
          }
        }
      },
      "additionalProperties": true
    },
    "position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "prefixItems": [
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "Longitude."
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "Latitude."
        },
        {
          "type": "number",
          "description": "Optional elevation."
        }
      ],
      "items": false
    },
    "properties": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        },
        "coordinateProperties": {
          "$ref": "#/$defs/coordinateProperties"
        }
      },
      "additionalProperties": true
    },
    "coordinateProperties": {
      "type": "object",
      "properties": {
        "times": {
          "$ref": "#/$defs/numberSeries"
        },
        "distances": {
          "$ref": "#/$defs/numberSeries"
        },
        "elevations": {
          "$ref": "#/$defs/numberSeries"
        },
        "heartRates": {
          "$ref": "#/$defs/numberSeries"
        },
        "cadences": {
          "$ref": "#/$defs/numberSeries"
        },
        "powers": {
          "$ref": "#/$defs/numberSeries"
        },
        "speeds": {
          "$ref": "#/$defs/numberSeries"
        }
      },
      "patternProperties": {
        "^(?!(__proto__|constructor|prototype)$)[A-Za-z_][A-Za-z0-9_]*$": {
          "$ref": "#/$defs/numberSeries"
        }
      },
      "additionalProperties": false
    },
    "numberSeries": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "formatVersion": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sport": {
          "type": "string"
        },
        "subSport": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        },
        "startTime": {
          "type": "number"
        },
        "totalDistanceM": {
          "type": "number"
        },
        "totalTimerTime": {
          "type": "number"
        },
        "totalElapsedTime": {
          "type": "number"
        },
        "device": {
          "type": "object",
          "properties": {
            "manufacturer": {
              "type": "string"
            },
            "product": {
              "type": "string"
            },
            "serialNumber": {
              "type": "number"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
