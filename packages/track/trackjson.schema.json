{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stgy.example/schemas/trackjson.schema.json",
  "title": "TrackJSON",
  "description": "GeoJSON-compatible route data format for stgy-track.",
  "oneOf": [
    {
      "$ref": "#/$defs/featureCollection"
    },
    {
      "$ref": "#/$defs/feature"
    }
  ],
  "$defs": {
    "featureCollection": {
      "type": "object",
      "required": [
        "type",
        "features"
      ],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "prefixItems": [
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180,
              "description": "West longitude."
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90,
              "description": "South latitude."
            },
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180,
              "description": "East longitude."
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90,
              "description": "North latitude."
            }
          ],
          "items": false
        },
        "poi": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pointOfInterest"
          }
        },
        "features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/feature"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      },
      "additionalProperties": true
    },
    "feature": {
      "type": "object",
      "required": [
        "type",
        "geometry",
        "properties"
      ],
      "properties": {
        "type": {
          "const": "Feature"
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "prefixItems": [
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180,
              "description": "West longitude."
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90,
              "description": "South latitude."
            },
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180,
              "description": "East longitude."
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90,
              "description": "North latitude."
            }
          ],
          "items": false
        },
        "poi": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pointOfInterest"
          }
        },
        "geometry": {
          "$ref": "#/$defs/lineStringGeometry"
        },
        "properties": {
          "$ref": "#/$defs/properties"
        }
      },
      "additionalProperties": true
    },
    "lineStringGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/position"
          }
        }
      },
      "additionalProperties": true
    },
    "position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "prefixItems": [
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "Longitude."
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "Latitude."
        },
        {
          "type": "number",
          "description": "Optional altitude."
        }
      ],
      "items": false
    },
    "horizontalPosition": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "Longitude."
        },
        {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "Latitude."
        }
      ],
      "items": false
    },
    "pointOfInterest": {
      "type": "object",
      "required": [
        "role",
        "coordinates"
      ],
      "properties": {
        "role": {
          "enum": [
            "start",
            "end",
            "centroid",
            "furthest"
          ]
        },
        "coordinates": {
          "$ref": "#/$defs/horizontalPosition"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "properties": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        },
        "coordinateProperties": {
          "$ref": "#/$defs/coordinateProperties"
        }
      },
      "additionalProperties": true
    },
    "coordinateProperties": {
      "type": "object",
      "properties": {
        "times": {
          "$ref": "#/$defs/numberSeries"
        },
        "distances": {
          "$ref": "#/$defs/numberSeries"
        },
        "altitudes": {
          "$ref": "#/$defs/numberSeries"
        },
        "heartRates": {
          "$ref": "#/$defs/numberSeries"
        },
        "cadences": {
          "$ref": "#/$defs/numberSeries"
        },
        "powers": {
          "$ref": "#/$defs/numberSeries"
        },
        "speeds": {
          "$ref": "#/$defs/numberSeries"
        }
      },
      "patternProperties": {
        "^(?!(__proto__|constructor|prototype)$)[A-Za-z_][A-Za-z0-9_]*$": {
          "$ref": "#/$defs/numberSeries"
        }
      },
      "additionalProperties": false
    },
    "numberSeries": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string"
            },
            "formatVersion": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sport": {
          "type": "string"
        },
        "subSport": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        },
        "startTime": {
          "type": "number"
        },
        "totalDistanceM": {
          "type": "number"
        },
        "ascentM": {
          "type": "number"
        },
        "descentM": {
          "type": "number"
        },
        "totalTimerTime": {
          "type": "number"
        },
        "totalElapsedTime": {
          "type": "number"
        },
        "analysis": {
          "$ref": "#/$defs/analysis"
        },
        "statistics": {
          "$ref": "#/$defs/statistics"
        },
        "training": {
          "$ref": "#/$defs/training"
        },
        "histograms": {
          "$ref": "#/$defs/histograms"
        },
        "pedaling": {
          "$ref": "#/$defs/pedaling"
        },
        "devices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/device"
          }
        },
        "recordingDevice": {
          "type": "object",
          "properties": {
            "manufacturer": {
              "type": "string"
            },
            "product": {
              "type": "string"
            },
            "serialNumber": {
              "type": "number"
            },
            "productName": {
              "type": "string"
            },
            "softwareVersion": {
              "type": "string"
            },
            "hardwareVersion": {
              "type": "string"
            },
            "deviceType": {
              "type": "string"
            },
            "sourceType": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "bestEfforts": {
          "$ref": "#/$defs/bestEfforts"
        },
        "pedalingDynamics": {
          "$ref": "#/$defs/pedalingDynamics"
        }
      },
      "additionalProperties": true
    },
    "analysis": {
      "type": "object",
      "properties": {
        "movingSpeedThresholdKph": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "statistics": {
      "type": "object",
      "properties": {
        "speedKph": {
          "$ref": "#/$defs/numericStats"
        },
        "cadenceRpm": {
          "$ref": "#/$defs/numericStats"
        },
        "heartRateBpm": {
          "$ref": "#/$defs/numericStats"
        },
        "powerW": {
          "$ref": "#/$defs/numericStats"
        },
        "temperatureC": {
          "$ref": "#/$defs/numericStats"
        }
      },
      "additionalProperties": true
    },
    "numericStats": {
      "type": "object",
      "properties": {
        "mean": {
          "type": "number"
        },
        "median": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "training": {
      "type": "object",
      "properties": {
        "normalizedPowerW": {
          "type": "number"
        },
        "totalWorkJ": {
          "type": "number"
        },
        "totalCaloriesCal": {
          "type": "number"
        },
        "source": {
          "type": "object",
          "properties": {
            "normalizedPower": {
              "enum": [
                "fit",
                "computed"
              ]
            },
            "totalWork": {
              "enum": [
                "fit",
                "computed"
              ]
            },
            "totalCalories": {
              "const": "fit"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "pedaling": {
      "type": "object",
      "properties": {
        "totalSeconds": {
          "type": "number"
        },
        "averageSpeedKph": {
          "type": "number"
        },
        "averageCadenceRpm": {
          "type": "number"
        },
        "averageHeartRateBpm": {
          "type": "number"
        },
        "averagePowerW": {
          "type": "number"
        },
        "normalizedPowerW": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "histograms": {
      "type": "object",
      "properties": {
        "speedKph": {
          "$ref": "#/$defs/speedHistogram"
        },
        "cadenceRpm": {
          "$ref": "#/$defs/cadenceHistogram"
        },
        "powerW": {
          "$ref": "#/$defs/powerHistogram"
        },
        "heartRateBpm": {
          "$ref": "#/$defs/heartRateHistogram"
        }
      },
      "additionalProperties": true
    },
    "speedHistogram": {
      "type": "object",
      "properties": {
        "bucketSizeKph": {
          "type": "number"
        },
        "maxBucketKph": {
          "type": "number"
        },
        "totalSeconds": {
          "type": "number"
        },
        "buckets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/histogramBucket"
          }
        }
      },
      "additionalProperties": true
    },
    "cadenceHistogram": {
      "type": "object",
      "properties": {
        "bucketSizeRpm": {
          "type": "number"
        },
        "maxBucketRpm": {
          "type": "number"
        },
        "totalSeconds": {
          "type": "number"
        },
        "buckets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/histogramBucket"
          }
        }
      },
      "additionalProperties": true
    },
    "powerHistogram": {
      "type": "object",
      "properties": {
        "bucketSizeW": {
          "type": "number"
        },
        "maxBucketW": {
          "type": "number"
        },
        "totalSeconds": {
          "type": "number"
        },
        "buckets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/histogramBucket"
          }
        }
      },
      "additionalProperties": true
    },
    "heartRateHistogram": {
      "type": "object",
      "properties": {
        "bucketSizeBpm": {
          "type": "number"
        },
        "firstBucketMaxBpm": {
          "type": "number"
        },
        "maxBucketBpm": {
          "type": "number"
        },
        "totalSeconds": {
          "type": "number"
        },
        "buckets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/histogramBucket"
          }
        }
      },
      "additionalProperties": true
    },
    "histogramBucket": {
      "type": "object",
      "required": [
        "label",
        "seconds"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "seconds": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "device": {
      "type": "object",
      "properties": {
        "manufacturer": {
          "type": "string"
        },
        "product": {
          "type": "string"
        },
        "serialNumber": {
          "type": "number"
        },
        "productName": {
          "type": "string"
        },
        "softwareVersion": {
          "type": "string"
        },
        "hardwareVersion": {
          "type": "string"
        },
        "deviceType": {
          "type": "string"
        },
        "sourceType": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "bestEfforts": {
      "type": "object",
      "properties": {
        "powerW": {
          "type": "object",
          "patternProperties": {
            "^[0-9]+$": {
              "type": "number"
            }
          },
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "additionalProperties": true
    },
    "pedalingDynamics": {
      "type": "object",
      "properties": {
        "leftRightBalance": {
          "$ref": "#/$defs/leftRightBalance"
        },
        "torqueEffectiveness": {
          "$ref": "#/$defs/pedalingSidePercentages"
        },
        "pedalSmoothness": {
          "$ref": "#/$defs/pedalingSidePercentages"
        }
      },
      "additionalProperties": true
    },
    "leftRightBalance": {
      "type": "object",
      "properties": {
        "leftPercentage": {
          "type": "number"
        },
        "rightPercentage": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "pedalingSidePercentages": {
      "type": "object",
      "properties": {
        "leftPercentage": {
          "type": "number"
        },
        "rightPercentage": {
          "type": "number"
        },
        "combinedPercentage": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  }
}
